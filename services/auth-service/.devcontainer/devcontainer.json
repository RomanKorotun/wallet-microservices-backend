{
  "name": "Auth Service Dev Container",
  "dockerComposeFile": [
    "../docker-compose.dev.yml",
    "../../../docker-compose.infra-core.yml"
  ],
  "service": "auth-service",
  "workspaceFolder": "/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "dev.containers.stopContainersWhenClosing": true
      }
    }
  }
}
